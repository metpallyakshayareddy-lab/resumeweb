generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String       @id @default(uuid())
  username  String       @unique
  email     String       @unique
  password  String
  createdAt DateTime     @default(now())
  resumes   Resume[]
  history   HistoryLog[]
}

model Resume {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  data      String    @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sections  Section[]
  versions  Version[]
}

model Section {
  id        String   @id @default(uuid())
  resumeId  String
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  type      String
  content   String    @default("{}")
}

model Template {
  id        String   @id @default(uuid())
  name      String
  layout    String    @default("{}")
}

model Version {
  id            String   @id @default(uuid())
  resumeId      String
  resume        Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  versionNumber Int
  createdAt     DateTime @default(now())
}

model HistoryLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  action    String
  createdAt DateTime @default(now())
}
